NEXT_PUBLIC_SITE_URL=https://millionmind.app

# Vercel KV — auto-injected when you connect a KV store to the project.
# Leave unset for local dev; rate-limit.ts uses an in-memory fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# PostHog — set after creating a project at https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — set after creating a project at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://...ingest.sentry.io/...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=millionmind-web
SENTRY_AUTH_TOKEN=sntrys_...

# Ads
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-...
NEXT_PUBLIC_H5_GAME_AD_UNIT_ID=
