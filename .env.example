# ──────────────────────────────────────────────────────────────────
# Million Mind — Environment Variables
# Copy to .env.local at repo root and fill in values.
# Apps read shared values; per-app .env files are also supported.
# ──────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────
# Get from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Mobile reads EXPO_PUBLIC_* (mirror of the values above)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — never expose to clients
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── RevenueCat ───────────────────────────────────────────────────
# Get from https://app.revenuecat.com/projects/<id>/api-keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...
NEXT_PUBLIC_REVENUECAT_WEB_KEY=rcb_...

# RevenueCat webhook auth header (server-only)
REVENUECAT_WEBHOOK_SECRET=

# ─── Powerball data loader (Python scripts) ──────────────────────
# DATABASE_URL points at Postgres directly for bulk inserts
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Optional — register at https://data.ny.gov/profile/app_tokens for higher rate limit
SOCRATA_APP_TOKEN=
