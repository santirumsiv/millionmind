# ──────────────────────────────────────────────────────────────────
# Million Mind — Environment Variables (web-only, ads-only)
# Copy to .env.local and fill in values.
# ──────────────────────────────────────────────────────────────────

# ─── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://millionmind.app

# ─── Canadian game backends (separate Python services) ───────────
# The CA section (/ca) proxies to three standalone Python services — one
# per game — via the adapter in apps/web/src/lib/ca-backends.ts. Defaults
# below match each project's local dev port. Leave unset to use defaults.
#   - Lotto 6/49 : FastAPI (ships ~4,385 real draws)
#   - Lotto Max  : Flask   (loads from an uploaded OLG "Since Inception" PDF)
#   - Daily Grand: Flask   (preloads embedded history; also accepts CSV/PDF)
CA_LOTTO649_API_URL=http://localhost:8000
CA_LOTTOMAX_API_URL=http://localhost:5050
CA_DAILYGRAND_API_URL=http://localhost:5051

# ─── Vercel KV (rate-limit + ad-grant counters) ──────────────────
# Vercel injects these automatically when you connect a KV store to
# the project. For local dev, leave them unset — rate-limit.ts falls
# back to an in-memory implementation.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── PostHog (product analytics) ─────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Sentry (error tracking) ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...ingest.sentry.io/...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=millionmind-web
SENTRY_AUTH_TOKEN=sntrys_...

# ─── Ads ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-...
NEXT_PUBLIC_H5_GAME_AD_UNIT_ID=
