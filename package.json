{
  "name": "millionmind",
  "version": "0.2.0",
  "private": true,
  "description": "Million Mind — Powerball & Mega Millions statistics, web-only ad-driven entertainment platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "web": "turbo run dev --filter=@millionmind/web",
    "data:refresh": "node scripts/refresh-drawings.mjs",
    "data:refresh:ca": "node scripts/refresh-ca-draws.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.12.1"
}
